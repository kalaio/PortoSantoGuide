generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRATOR
  OWNER
  SUBSCRIBER
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ListingRevisionStatus {
  DRAFT
  PUBLISHED
}

model User {
  id                     String            @id @default(cuid())
  username               String            @unique
  email                  String            @unique
  passwordHash           String
  role                   Role
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  sessions               Session[]
  listings               Listing[]
  createdListingRevisions ListingRevision[] @relation("CreatedListingRevisions")
  updatedListingRevisions ListingRevision[] @relation("UpdatedListingRevisions")
}

model DirectorySection {
  id         String            @id @default(cuid())
  slug       String            @unique
  label      String
  sortOrder  Int               @default(0)
  isActive   Boolean           @default(true)
  categories ListingCategory[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([isActive, sortOrder])
}

model ListingSchema {
  id          String               @id @default(cuid())
  slug        String               @unique
  label       String
  description String?
  sortOrder   Int                  @default(0)
  isActive    Boolean              @default(true)
  categories  ListingCategory[]
  fields      ListingSchemaField[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([isActive, sortOrder])
}

model ListingSchemaField {
  schemaId   String
  fieldKey   String
  sortOrder  Int      @default(0)
  isRequired Boolean  @default(false)
  isFrontendFilterEnabled Boolean @default(false)
  schema     ListingSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  @@id([schemaId, fieldKey])
  @@index([schemaId, sortOrder])
}

model ListingCategory {
  id              String                      @id @default(cuid())
  slug            String                      @unique
  label           String
  iconName        String?
  sectionId       String
  section         DirectorySection            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schemaId        String?
  schema          ListingSchema?              @relation(fields: [schemaId], references: [id], onDelete: SetNull)
  sortOrder       Int                         @default(0)
  isActive        Boolean                     @default(true)
  primaryListings Listing[]                   @relation("PrimaryListingCategory")
  assignments     ListingCategoryAssignment[]
  revisionPrimaryListings ListingRevision[]
  revisionAssignments ListingRevisionCategoryAssignment[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([sectionId, isActive, sortOrder])
}

model Session {
  id        String    @id @default(cuid())
  tokenId   String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RateLimitBucket {
  key         String   @id
  scope       String
  count       Int      @default(0)
  windowStart DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, updatedAt])
}

model SearchSuggestion {
  id        String   @id @default(cuid())
  label     String
  query     String
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, priority])
}

model Listing {
  id                     String                      @id @default(cuid())
  slug                   String                      @unique
  title                  String
  description            String?
  status                 ListingStatus               @default(DRAFT)
  latitude               Float?
  longitude              Float?
  rating                 Float                       @default(0)
  details                Json?
  primaryCategoryId      String
  primaryCategory        ListingCategory             @relation("PrimaryListingCategory", fields: [primaryCategoryId], references: [id], onDelete: Restrict)
  categories             ListingCategoryAssignment[]
  currentPublishedRevisionId String?                 @unique
  currentPublishedRevision   ListingRevision?        @relation("CurrentPublishedRevision", fields: [currentPublishedRevisionId], references: [id], onDelete: SetNull)
  currentDraftRevisionId String?                     @unique
  currentDraftRevision   ListingRevision?            @relation("CurrentDraftRevision", fields: [currentDraftRevisionId], references: [id], onDelete: SetNull)
  revisions              ListingRevision[]           @relation("ListingRevisions")
  ownerId                String?
  owner                  User?                       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  @@index([ownerId])
  @@index([ownerId, updatedAt])
  @@index([primaryCategoryId])
  @@index([status, createdAt])
  @@index([status, updatedAt])
}

model ListingRevision {
  id                      String                              @id @default(cuid())
  listingId               String
  listing                 Listing                             @relation("ListingRevisions", fields: [listingId], references: [id], onDelete: Cascade)
  currentPublishedForListing Listing?                         @relation("CurrentPublishedRevision")
  currentDraftForListing  Listing?                           @relation("CurrentDraftRevision")
  slug                    String
  title                   String
  description             String?
  status                  ListingRevisionStatus              @default(DRAFT)
  latitude                Float?
  longitude               Float?
  details                 Json?
  primaryCategoryId       String
  primaryCategory         ListingCategory                     @relation(fields: [primaryCategoryId], references: [id], onDelete: Restrict)
  categories              ListingRevisionCategoryAssignment[]
  createdById             String?
  createdBy               User?                               @relation("CreatedListingRevisions", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById             String?
  updatedBy               User?                               @relation("UpdatedListingRevisions", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt               DateTime                            @default(now())
  updatedAt               DateTime                            @updatedAt

  @@index([listingId])
  @@index([listingId, status, updatedAt])
  @@index([primaryCategoryId])
  @@index([status, updatedAt])
}

model ListingRevisionCategoryAssignment {
  revisionId String
  categoryId String
  revision   ListingRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  category   ListingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@id([revisionId, categoryId])
  @@index([categoryId])
}

model ListingCategoryAssignment {
  listingId  String
  categoryId String
  listing    Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  category   ListingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@id([listingId, categoryId])
  @@index([categoryId])
}

model Slider {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  isActive  Boolean @default(true)
  slides    Slide[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Slide {
  id           String  @id @default(cuid())
  sliderId     String
  title        String?
  description  String?
  mediaDesktop String?
  mediaDesktopThumb String?
  mediaMobile  String?
  mediaMobileThumb String?
  videoUrl     String?
  order        Int     @default(0)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  slider       Slider  @relation(fields: [sliderId], references: [id], onDelete: Cascade)

  @@index([sliderId, order])
}
